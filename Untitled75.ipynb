        "<!DOCTYPE html>\n",
        "<html lang=\"pt-BR\">\n",
        "<head>\n",
        "<meta charset=\"UTF-8\">\n",
        "<title>Sistema Solar 2D</title>\n",
        "<style>\n",
        "  canvas {\n",
        "    background: radial-gradient(circle, #000010, #000000);\n",
        "    display: block;\n",
        "    margin: auto;\n",
        "  }\n",
        "</style>\n",
        "</head>\n",
        "<body>\n",
        "\n",
        "<canvas id=\"canvas\" width=\"800\" height=\"600\"></canvas>\n",
        "\n",
        "<script>\n",
        "const canvas = document.getElementById(\"canvas\");\n",
        "const ctx = canvas.getContext(\"2d\");\n",
        "\n",
        "let angle = 0;\n",
        "let moonAngle = 0;\n",
        "\n",
        "// Nave\n",
        "let shipX = 400;\n",
        "let shipY = 500;\n",
        "let shipAngle = 0;\n",
        "\n",
        "// Estrelas\n",
        "let stars = Array.from({length: 100}, () => ({\n",
        "  x: Math.random() * canvas.width,\n",
        "  y: Math.random() * canvas.height\n",
        "}));\n",
        "\n",
        "// Controle teclado\n",
        "document.addEventListener(\"keydown\", (e) => {\n",
        "  if (e.key === \"ArrowLeft\") {\n",
        "    shipX -= 10;\n",
        "    shipAngle = -0.3;\n",
        "  }\n",
        "  if (e.key === \"ArrowRight\") {\n",
        "    shipX += 10;\n",
        "    shipAngle = 0.3;\n",
        "  }\n",
        "  if (e.key === \"ArrowUp\") shipY -= 10;\n",
        "  if (e.key === \"ArrowDown\") shipY += 10;\n",
        "});\n",
        "\n",
        "// ⭐ Estrelas\n",
        "function drawStars() {\n",
        "  ctx.fillStyle = \"white\";\n",
        "  stars.forEach(s => {\n",
        "    ctx.fillRect(s.x, s.y, 2, 2);\n",
        "  });\n",
        "}\n",
        "\n",
        "// ☀️ Sol com brilho\n",
        "function drawSun() {\n",
        "  let gradient = ctx.createRadialGradient(0, 0, 10, 0, 0, 50);\n",
        "  gradient.addColorStop(0, \"yellow\");\n",
        "  gradient.addColorStop(1, \"orange\");\n",
        "\n",
        "  ctx.fillStyle = gradient;\n",
        "  ctx.beginPath();\n",
        "  ctx.arc(0, 0, 40, 0, Math.PI * 2);\n",
        "  ctx.fill();\n",
        "}\n",
        "\n",
        "// 🌍 Planeta\n",
        "function drawPlanet() {\n",
        "  ctx.fillStyle = \"blue\";\n",
        "  ctx.beginPath();\n",
        "  ctx.arc(0, 0, 20, 0, Math.PI * 2);\n",
        "  ctx.fill();\n",
        "}\n",
        "\n",
        "// 🌙 Lua\n",
        "function drawMoon() {\n",
        "  ctx.fillStyle = \"gray\";\n",
        "  ctx.beginPath();\n",
        "  ctx.arc(0, 0, 10, 0, Math.PI * 2);\n",
        "  ctx.fill();\n",
        "}\n",
        "\n",
        "// 🚀 Nave\n",
        "function drawShip() {\n",
        "  ctx.save();\n",
        "  ctx.translate(shipX, shipY);\n",
        "  ctx.rotate(shipAngle);\n",
        "\n",
        "  ctx.fillStyle = \"white\";\n",
        "  ctx.beginPath();\n",
        "  ctx.moveTo(0, -12);\n",
        "  ctx.lineTo(-10, 10);\n",
        "  ctx.lineTo(10, 10);\n",
        "  ctx.closePath();\n",
        "  ctx.fill();\n",
        "\n",
        "  ctx.restore();\n",
        "}\n",
        "\n",
        "// 🎬 Loop principal\n",
        "function draw() {\n",
        "  ctx.setTransform(1,0,0,1,0,0);\n",
        "  ctx.clearRect(0, 0, canvas.width, canvas.height);\n",
        "\n",
        "  drawStars();\n",
        "\n",
        "  // SOL\n",
        "  ctx.save();\n",
        "  ctx.translate(400, 300);\n",
        "  drawSun();\n",
        "\n",
        "  // ÓRBITA DO PLANETA\n",
        "  ctx.rotate(angle);\n",
        "\n",
        "  ctx.save();\n",
        "  ctx.translate(150, 0);\n",
        "\n",
        "  drawPlanet();\n",
        "\n",
        "  // LUA (hierarquia)\n",
        "  ctx.rotate(moonAngle);\n",
        "\n",
        "  ctx.save();\n",
        "  ctx.translate(50, 0);\n",
        "  ctx.scale(0.6, 0.6);\n",
        "  drawMoon();\n",
        "  ctx.restore();\n",
        "\n",
        "  ctx.restore();\n",
        "  ctx.restore();\n",
        "\n",
        "  drawShip();\n",
        "\n",
        "  angle += 0.01;\n",
        "  moonAngle += 0.03;\n",
        "\n",
        "  requestAnimationFrame(draw);\n",
        "}\n",
        "\n",
        "draw();\n",
        "</script>\n",
        "\n",
        "</body>\n",
        "</html>"
      ]
    }
  ]
}
